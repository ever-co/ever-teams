# ChatGPT App Server Configuration
CHATGPT_APP_PORT=3004
CHATGPT_APP_HOST=localhost

# Public URL (ngrok or production URL - used for OAuth callbacks)
# Leave empty for localhost development
PUBLIC_URL=

# MCP Server Configuration (existing infrastructure)
# For demo: https://mcpdemo.ever.team
# For prod: https://mcp.ever.team
MCP_SERVER_URL=https://mcp.ever.team

# OAuth Server Configuration
# For demo: https://mcpauthdemo.ever.team
# For prod: https://mcpauth.ever.team
OAUTH_SERVER_URL=https://mcpauth.ever.team

# ChatGPT App Credentials (from OpenAI Developer Platform)
CHATGPT_APP_ID=your-app-id-from-openai
CHATGPT_APP_SECRET=your-app-secret-from-openai

# CORS Configuration
ALLOWED_ORIGINS=https://chat.openai.com,https://chatgpt.com

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Security
SESSION_SECRET=your-secure-session-secret-change-in-production
